{
  "name": "cypress-framework",
  "version": "1.0.0",
  "description": "Senior-level Cypress automation framework",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js'",
    "cy:run:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "cy:run:network": "cypress run --spec 'cypress/e2e/network/**/*.cy.js'",
    "cy:run:chrome": "cypress run --browser chrome"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cypress": "^15.13.0"
  }
}